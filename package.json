{
  "name": "levain",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "mobile": "pnpm --filter mobile start",
    "mobile:ios": "pnpm --filter mobile ios",
    "mobile:web": "pnpm --filter mobile web",
    "web": "pnpm --filter web dev",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "tsc:check": "turbo check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  }
}
